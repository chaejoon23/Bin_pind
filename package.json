{
  "name": "pind",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter=./apps/web --filter=./apps/extension dev",
    "build": "pnpm --recursive build",
    "lint": "pnpm --recursive lint",
    "typecheck": "pnpm --recursive typecheck",
    "verify": "pnpm lint && pnpm typecheck"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
